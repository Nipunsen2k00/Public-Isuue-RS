rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Profile pictures rules
    match /profilePics/{userId}/{fileName} {
      // Anyone can read profile pictures
      allow read: if true;
      // Only the authenticated user can upload/modify their own profile picture
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Reports rules
    match /reports/{userId}/{fileName} {
      // Anyone can read images attached to reports (needed for community feed)
      allow read: if true;
      // Only the authenticated user can upload images to their own report folder
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
